# Tadpole Decky Plugin Environment Variables
# Copy this file to .env and fill in your values

# Bridge server port (default: 3456)
PORT=3456

# Path to Lua mod state file (writable by the bridge)
STATE_FILE=/home/deck/.steam/steam/steamapps/compatdata/1086940/pfx/drive_c/users/steamuser/AppData/Local/Larian Studios/Baldur's Gate 3/PlayerProfiles/Public/tadpole_state.json

# Path to Lua mod command file (writable by the bridge)
COMMAND_FILE=/home/deck/.steam/steam/steamapps/compatdata/1086940/pfx/drive_c/users/steamuser/AppData/Local/Larian Studios/Baldur's Gate 3/PlayerProfiles/Public/tadpole_commands.json

# PocketBase error reporting endpoint (optional)
PB_ERROR_ENDPOINT=https://pb.gohanlab.uk/api/collections/tadpole_errors/records

# Bridge auth token (auto-generated if not set)
BRIDGE_TOKEN=

# mDNS hostname (default: tadpole)
MDNS_HOSTNAME=tadpole
