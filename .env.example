# Tadpole Bridge Server Configuration
# Copy this file to .env and edit as needed.

# Authentication token for write operations (commands over WebSocket).
# If not set, a random token is auto-generated on each start and printed to the console.
# Set a fixed value here for persistent auth across restarts.
BRIDGE_TOKEN=

# Port the bridge server listens on (default: 3456)
PORT=3456

# Path to the game state file written by the Lua mod
# (default: OS temp dir /tadpole_state.json)
STATE_FILE=

# Path to the command file read by the Lua mod
# (default: OS temp dir /tadpole_commands.json)
COMMAND_FILE=

# PocketBase error reporting endpoint (leave empty to use default)
PB_ERROR_ENDPOINT=https://pb.gohanlab.uk/api/collections/tadpole_errors/records

# mDNS hostname for automatic discovery on the local network (default: tadpole)
# The bridge will be reachable as <MDNS_HOSTNAME>.local (e.g. tadpole.local)
# Requires the bonjour-service npm package — if not installed, mDNS is skipped gracefully.
MDNS_HOSTNAME=tadpole
